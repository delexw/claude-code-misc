{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // Next.js needs browser + DOM types on top of the parent's node types
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    // Emit is handled by Next.js — disable the parent's outDir/rootDir
    "noEmit": true,
    "outDir": null,
    "rootDir": null,
    // JSX must be "preserve" for Next.js (SWC handles the transform)
    "jsx": "preserve",
    // Next.js language service plugin
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Incremental compilation cache
    "incremental": true,
    // Path alias used throughout the app
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
